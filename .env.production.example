# Production environment variables for Top-Gold
# Copy this file to .env.production and fill in real values

# Platega.io credentials (required for real payments)
PLATEGA_MERCHANT_ID=your_merchant_id_here
PLATEGA_API_KEY=your_api_key_here

# Base URL of your application (e.g., https://yourdomain.com)
NEXT_PUBLIC_BASE_URL=https://topgold.store

# Use mock payment in production? Set to false for real payments
NEXT_PUBLIC_USE_MOCK_PAYMENT=false

# Optional: Database or other services
# DATABASE_URL=postgresql://user:password@host:port/db

# Port for Next.js server (default 3000)
PORT=3000